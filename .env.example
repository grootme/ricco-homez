# ===========================================
# Homez Dev Environment Configuration
# ===========================================

# ===========================================
# Database Configuration
# ===========================================
# SQLite for development
DATABASE_URL="file:./dev.db"

# ===========================================
# Authentication (NextAuth.js)
# ===========================================
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ===========================================
# API Gateway Configuration
# ===========================================
# Main API Gateway URL
API_GATEWAY_URL="http://api.ricco.com"

# ===========================================
# ricco-id Configuration
# ===========================================
# ricco-id authentication service URL
RICCO_ID_URL="http://id.ricco.com"
RICCO_ID_CLIENT_ID="homez-dev"
RICCO_ID_CLIENT_SECRET="your-client-secret"

# ===========================================
# ricco-ai Configuration
# ===========================================
# ricco-ai service endpoint
RICCO_AI_URL="http://api.ricco.com/v1/ai"
RICCO_AI_API_KEY="your-ai-api-key"

# ===========================================
# ricco-payment Configuration
# ===========================================
# ricco-payment service endpoint
RICCO_PAYMENT_URL="http://api.ricco.com/v1/payment"
RICCO_PAYMENT_API_KEY="your-payment-api-key"

# ===========================================
# Provider Configuration
# ===========================================
# Auth provider: "mock", "ricco-id", or "database"
# mock: In-memory mock authentication (default for development)
# ricco-id: ricco-id authentication service
# database: Database-backed authentication
AUTH_PROVIDER="mock"

# Data provider: "mock" or "database"
# mock: In-memory mock data (default for development)
# database: Prisma database
DATA_PROVIDER="mock"

# ===========================================
# Feature Flags
# ===========================================
# Data source: "DATABASE" or "API"
# DATABASE: Use local Prisma database
# API: Use remote API gateway
DATA_SOURCE="DATABASE"

# Enable/disable features
ENABLE_AI_FEATURES="true"
ENABLE_PAYMENT_FEATURES="true"
ENABLE_VIRTUAL_TOURS="true"
ENABLE_MORTGAGE_CALCULATOR="true"

# ===========================================
# External Services
# ===========================================
# Map services
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"
MAPBOX_ACCESS_TOKEN="your-mapbox-token"

# Storage
STORAGE_PROVIDER="local"  # local, s3, cloudinary
S3_BUCKET="your-bucket-name"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_REGION="us-east-1"

# Email
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-smtp-user"
SMTP_PASSWORD="your-smtp-password"
EMAIL_FROM="noreply@homez.com"

# ===========================================
# Application Settings
# ===========================================
# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Homez Dev"

# Debug mode
DEBUG_MODE="true"
LOG_LEVEL="debug"  # error, warn, info, debug

# ===========================================
# Analytics & Monitoring
# ===========================================
# Google Analytics
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Sentry (Error tracking)
NEXT_PUBLIC_SENTRY_DSN=""

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW_MS="60000"
