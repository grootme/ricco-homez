{
  "analysisDate": "2025-04-05",
  "task": "Analyze Listing Pages from Homez Real Estate Template",
  "baseUrl": "https://homez-appdir.vercel.app/",
  "pagesAnalyzed": 15,
  
  "gsapAnalysis": {
    "gsapUsed": false,
    "note": "GSAP is NOT used in this template. Alternative animation libraries are used instead.",
    "alternativeLibraries": [
      {
        "name": "AOS",
        "version": "^2.3.4",
        "purpose": "Animate On Scroll - triggers animations when elements enter viewport",
        "configuration": {
          "duration": 1200,
          "easing": "ease",
          "once": true,
          "offset": 120
        }
      },
      {
        "name": "WOW.js",
        "version": "^1.2.2",
        "purpose": "Reveal animations on scroll"
      },
      {
        "name": "CSS Transitions",
        "purpose": "Hover effects and simple animations"
      }
    ]
  },
  
  "animationTypes": [
    {
      "type": "fade-up",
      "description": "Fade in from bottom",
      "cssTransform": "translateY(100px) → translateY(0)",
      "duration": "1200ms"
    },
    {
      "type": "fade-down",
      "description": "Fade in from top",
      "cssTransform": "translateY(-100px) → translateY(0)",
      "duration": "1200ms"
    },
    {
      "type": "fade-left",
      "description": "Fade in from right",
      "cssTransform": "translateX(100px) → translateX(0)",
      "duration": "1200ms"
    },
    {
      "type": "fade-right",
      "description": "Fade in from left",
      "cssTransform": "translateX(-100px) → translateX(0)",
      "duration": "1200ms"
    },
    {
      "type": "zoom-in",
      "description": "Scale up effect",
      "cssTransform": "scale(0.6) → scale(1)",
      "duration": "1200ms"
    }
  ],
  
  "hoverAnimations": {
    "cardHover": {
      "transform": "translateY(-5px)",
      "boxShadow": "0 15px 40px rgba(0, 0, 0, 0.1)",
      "transition": "all 0.3s ease"
    },
    "buttonHover": {
      "transform": "translateY(-2px)",
      "boxShadow": "0 5px 20px rgba(0, 0, 0, 0.15)",
      "transition": "all 0.3s ease"
    },
    "imageZoom": {
      "transform": "scale(1.05)",
      "transition": "transform 0.5s ease"
    }
  },
  
